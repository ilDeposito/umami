APP_SECRET=replace-with-output-of-openssl-rand-hex-32
POSTGRES_PASSWORD=replace-with-a-strong-random-password

# Password for the dedicated, read-only Postgres role used by the SSO
# bridge (see db-init/01-sso-bridge-role.sql). After changing this, apply
# it with:
#   docker exec -i ildeposito_stats_postgres psql -U umami -d umami \
#     -c "ALTER ROLE umami_sso_bridge WITH PASSWORD '<value>';"
SSO_BRIDGE_DB_PASSWORD=replace-with-output-of-openssl-rand-hex-32

# Shared secret Caddy sends to the SSO bridge so it can tell a legitimate,
# Authelia-verified request apart from any other container on the shared
# "caddy" network trying to call the bridge directly.
SSO_BRIDGE_SHARED_SECRET=replace-with-output-of-openssl-rand-hex-32
